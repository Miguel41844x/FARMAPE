# FARMAPE microservices local environment

CONFIG_SERVER_PORT=8888
EUREKA_SERVER_PORT=8761
GATEWAY_PORT=8080
INVENTARIO_PORT=8081
INVENTARIO_MYSQL_PORT=3307

CONFIG_SERVER_URL=http://config-server:8888
EUREKA_SERVER_URL=http://eureka-server:8761/eureka/

INVENTARIO_DB_NAME=farmape_inventario
INVENTARIO_DB_USER=farmape
INVENTARIO_DB_PASSWORD=farmape
INVENTARIO_DB_ROOT_PASSWORD=root
INVENTARIO_DATASOURCE_URL=jdbc:mysql://mysql-inventario:3306/farmape_inventario?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

FRONTEND_LOCAL_ORIGIN=http://localhost:5173
FRONTEND_ALLOWED_ORIGIN_PATTERN=https://*.vercel.app

JAVA_OPTS=-Xmx300m -Xss512k
